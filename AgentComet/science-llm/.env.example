# Science LLM Configuration
# Copy this to .env and customize as needed

# ── Model ──────────────────────────────────────────────────────────────────
# Ollama model tag (set by setup.sh)
MODEL_NAME=mistral:7b-instruct-v0.3-q4_K_M

# HuggingFace model ID for MLX fine-tuning
MLX_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Ollama server address
OLLAMA_HOST=http://localhost:11434

# ── RAG Pipeline ───────────────────────────────────────────────────────────
# Path to your PDF/book collection
DOCS_PATH=./docs

# ChromaDB vector database location
CHROMA_DB_PATH=./rag/vectordb

# Local embedding model (no API needed, ~130MB download on first run)
# Options: BAAI/bge-small-en-v1.5 (fast), BAAI/bge-large-en-v1.5 (accurate)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Text chunking settings
CHUNK_SIZE=1024         # tokens per chunk (larger = more context)
CHUNK_OVERLAP=128       # overlap between consecutive chunks

# Number of chunks to retrieve per query (increase for complex questions)
TOP_K_RETRIEVAL=5

# ── Fine-tuning ────────────────────────────────────────────────────────────
FINETUNE_DATA_PATH=./finetune/data
